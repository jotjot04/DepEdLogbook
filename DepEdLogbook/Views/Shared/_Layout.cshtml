<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="~/favicon/DepEd.ico" alt ="DepEd Logo"/>
    <title>@ViewData["Title"] — DepEd SDO Accounting Digital Logbook</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <header class="app-header">
            <div class="header-brand">
                <div class="deped-logo">
                    <img src="~/images/Deped.png" alt="DepEd Logo"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                    <div class="logo-fallback" style="display:none"><i class="fas fa-sun"></i></div>
                </div>
                <div class="brand-text">
                    <span class="brand-main">Department of Education</span>
                    <span class="brand-sub">Schools Division Office — Accounting Office</span>
                </div>
            </div>

            <div class="header-title-center">
                <h1 class="logbook-title">
                    <i class="fas fa-book-open"></i> Digital Receiving Logbook
                </h1>
            </div>

            <div class="header-actions">
                <div class="live-badge">
                    <span class="live-dot"></span>
                    <span id="headerDate"></span>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <!-- ADMIN NAV -->
                    <a asp-controller="Admin" asp-action="Accounts" class="btn-audit">
                        <i class="fas fa-users-cog"></i> Manage Accounts
                    </a>
                    <a asp-controller="Admin" asp-action="AuditTrail" class="btn-audit">
                        <i class="fas fa-clipboard-list"></i> Audit Trail
                    </a>
                    <div class="user-chip user-chip-admin">
                        <i class="fas fa-user-shield"></i>
                        <span>Administrator</span>
                    </div>
                }
                else
                {
                    <!-- STAFF NAV -->
                    <a asp-controller="Home" asp-action="AuditTrail" class="btn-audit">
                        <i class="fas fa-clipboard-list"></i> Audit Trail
                    </a>
                    <div class="user-chip">
                        <i class="fas fa-id-badge"></i>
                        <span>@(User.FindFirst("UnitFullName")?.Value ?? User.Identity!.Name)</span>
                    </div>
                }

                <button type="button" class="btn-logout" title="Sign Out" onclick="showLogoutModal()">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
                <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" style="display:none">
                    @Html.AntiForgeryToken()
                </form>
            </div>
        </header>
    }

    <main class="@(User.Identity?.IsAuthenticated == true ? "main-content" : "")">
        @if (TempData["Success"] != null)
        {
            <div class="toast-success" id="toastSuccess">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @RenderBody()
    </main>

    <!-- LOGOUT MODAL -->
    <div id="logoutModal" class="modal-overlay" style="display:none;">
        <div class="modal-box">
            <div class="modal-icon modal-icon-warning"><i class="fas fa-sign-out-alt"></i></div>
            <h3 class="modal-title">Sign Out?</h3>
            <p class="modal-message">Are you sure you want to sign out of the system?</p>
            <div class="modal-actions">
                <button type="button" class="btn-modal-cancel" onclick="closeLogoutModal()">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button type="button" class="btn-modal-confirm btn-modal-warning"
                        onclick="document.getElementById('logoutForm').submit()">
                    <i class="fas fa-sign-out-alt"></i> Yes, Sign Out
                </button>
            </div>
        </div>
    </div>

    <script>
        function updateHeaderDate() {
            const el = document.getElementById('headerDate');
            if (!el) return;
            el.textContent = new Date().toLocaleDateString('en-PH',
                { weekday:'short', year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
        }
        updateHeaderDate(); setInterval(updateHeaderDate, 10000);

        const toast = document.getElementById('toastSuccess');
        if (toast) { toast.classList.add('show'); setTimeout(() => toast.classList.remove('show'), 4000); }

        function showLogoutModal()  { document.getElementById('logoutModal').style.display = 'flex'; }
        function closeLogoutModal() { document.getElementById('logoutModal').style.display = 'none'; }
        document.getElementById('logoutModal')?.addEventListener('click', e => { if (e.target === document.getElementById('logoutModal')) closeLogoutModal(); });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
