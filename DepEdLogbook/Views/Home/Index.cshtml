@model LogbookIndexViewModel
@{
    ViewData["Title"] = "Logbook Dashboard";

    var depts = new (string FullName, string Acronym)[]
    {
        ("Schools Division Office", "SDO"),
        ("Assistant Schools Division Superintendent", "ASDS"),
        ("Records Section", "RECORDS"),
        ("Human Resource Section", "HR"),
        ("Learning Resources Section", "LR"),
        ("School Governance and Operations Division", "SGOD"),
        ("Curriculum and Instruction Division", "CID"),
        ("Budget Section", "BUDGET"),
        ("Bids and Awards Committee", "BAC"),
        ("Cash Section", "CASH"),
        ("Administrative Division", "ADMIN"),
        ("Schools Division Superintendent", "SDS"),
        ("Supply and Property Unit", "SUPPLY & PROPERTY UNIT"),
        ("Legal Unit", "LEGAL UNIT"),
    };

    var receivers = new[]
    {
        "Sir Ketch", "Sir Carl", "Sir Harlan", "Sir Rob", "Sir Mak",
        "Ma'am Tin", "Ma'am Eli", "Ma'am Zyle", "Ma'am She"
    };

    var docTypes = new[]
    {
        "Request Letter", "Letter of Introduction (LOI)", "Transmittal Letter",
        "Justification Letter", "Demand Letter",
        "Disbursement Voucher (DV)", "Obligation Request and Status (ORS)",
        "Payroll Register", "Daily Time Record (DTR)", "Purchase Request (PR)",
        "Purchase Order (PO)", "Inspection and Acceptance Report (IAR)",
        "Inventory Custodian Slip (ICS)", "Property Acknowledgment Receipt (PAR)",
        "Liquidation Report (LR)", "Cash Disbursement Register (CDR)",
        "Bank Reconciliation Statement", "Trial Balance",
        "Statement of Expenditures (SOE)",
        "Registry of Allotments, Obligations, and Disbursements (RAOD)",
        "Official Receipt (OR)", "Sales Invoice (SI)", "Bidding Documents",
        "Notarized Contracts", "Program of Works (POW)",
        "Certificate of Appearance", "Travel Order",
        "BIR Form 2306", "BIR Form 2307", "Summary of Tax Withheld",
        "Notice of Salary Adjustment (NOSA)", "Notice of Step Increment (NOSI)",
        "Service Record", "Appointment (CS Form No. 33)",
        "Maintenance and Other Operating Expenses (MOOE)", "Advice/Authority to Debit Account (ADA)"
    };
}

<!-- STATS CARDS -->
<section class="stats-section">
    <div class="stat-card stat-total">
        <div class="stat-icon"><i class="fas fa-book"></i></div>
        <div class="stat-info"><span class="stat-value">@Model.TotalEntries</span><span class="stat-label">Total Entries</span></div>
    </div>
    <div class="stat-card stat-today">
        <div class="stat-icon"><i class="fas fa-calendar-day"></i></div>
        <div class="stat-info"><span class="stat-value">@Model.ReceivedToday</span><span class="stat-label">Received Today</span></div>
    </div>
    <div class="stat-card stat-depts">
        <div class="stat-icon"><i class="fas fa-building"></i></div>
        <div class="stat-info"><span class="stat-value">@Model.TotalDepartments</span><span class="stat-label">Departments</span></div>
    </div>
    <div class="stat-card stat-docs">
        <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
        <div class="stat-info"><span class="stat-value">@Model.TotalDocuments</span><span class="stat-label">Total Documents</span></div>
    </div>
</section>

<!-- NEW ENTRY FORM -->
<section class="form-section">
    <div class="section-header">
        <h2><i class="fas fa-plus-circle"></i> New Logbook Entry</h2>
    </div>

    <form asp-action="Create" method="post" id="newEntryForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert-error mb-2"></div>

        <div class="form-row">
            <div class="form-group flex-2">
                <label class="form-label"><i class="fas fa-building"></i> Department / Office / Specific</label>
                <div class="combo-wrap">
                    <input type="text" name="Department" id="deptInput" class="form-control"
                           placeholder="Type or select department..."
                           value="@Model.NewEntry.Department" autocomplete="off" />
                    <i class="fas fa-chevron-down combo-arrow"></i>
                    <div id="deptDropdown" class="dept-dropdown" style="display:none;"></div>
                </div>
            </div>
            <div class="form-group flex-1">
                <label class="form-label"><i class="fas fa-calendar-alt"></i> Date & Time Received</label>
                <input type="datetime-local" name="DateTimeReceived" class="form-control"
                       value="@Model.NewEntry.DateTimeReceived.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group flex-2">
                <label class="form-label"><i class="fas fa-user-check"></i> Received By</label>
                <div class="combo-wrap">
                    <select name="ReceivedBy" class="form-control" required>
                        <option value="">-- Select Receiver --</option>
                        @foreach (var r in receivers)
                        {
                            if (Model.NewEntry.ReceivedBy == r)
                            {
                                <option value="@r" selected>@r</option>
                            }
                            else
                            {
                                <option value="@r">@r</option>
                            }
                        }
                    </select>
                    <i class="fas fa-chevron-down combo-arrow"></i>
                </div>
            </div>
        </div>

        <!-- DOCUMENT ROWS -->
        <div class="doc-table-wrap">
            <div class="doc-table-header">
                <span class="col-doctype">Document Type <span style="color:#fca5a5">*</span></span>
                <span class="col-code">Doc Code</span>
                <span class="col-particulars">Particulars <span style="color:#fca5a5">*</span></span>
                <span class="col-remarks">Remarks/Others</span>
                <span class="col-action"></span>
            </div>
            <div id="docRows">
                <div class="doc-row">
                    <div class="combo-wrap">
                        <select name="Documents[0].DocumentType" class="form-control doc-type-select" required>
                            <option value="">-- Select Type --</option>
                            @foreach (var t in docTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                        <i class="fas fa-chevron-down combo-arrow"></i>
                    </div>
                    <input type="text" name="Documents[0].DocCode" class="form-control" placeholder="e.g. DV-001 (optional)" />
                    <input type="text" name="Documents[0].Particulars" class="form-control" placeholder="Document particulars..." />
                    <input type="text" name="Documents[0].Remarks" class="form-control" placeholder="Note/Annotation" />
                    <button type="button" class="btn-remove-row" onclick="removeRow(this)" disabled>
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <button type="button" class="btn-add-row" onclick="addDocRow()">
                <i class="fas fa-plus"></i> Add Document Row
            </button>
            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i> Save Entry
            </button>
        </div>
    </form>
</section>

<!-- LOGBOOK RECORDS -->
<section class="logbook-section" id="logbookSection">
    <div class="section-header">
        <h2><i class="fas fa-table"></i> Logbook Records</h2>
        <div style="display:flex;gap:.6rem;align-items:center;">
            <span class="record-count">@Model.TotalEntries total record(s)</span>
            <button type="button" class="btn-export-csv" onclick="exportCsv()" title="Export to CSV/Excel">
                <i class="fas fa-file-excel"></i> Export
            </button>
            <button type="button" class="btn-print" onclick="printPreview()" title="Print">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>

    <div class="filter-bar">
        <div class="filter-group">
            <label><i class="fas fa-calendar"></i> From</label>
            <input type="date" id="filterFrom" class="form-control sm" value="@Model.FilterFrom?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label><i class="fas fa-calendar"></i> To</label>
            <input type="date" id="filterTo" class="form-control sm" value="@Model.FilterTo?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group" style="position:relative;">
            <label><i class="fas fa-building"></i> Department or Code</label>
            <div class="combo-wrap">
                <input type="text" id="filterDept" class="form-control sm"
                       placeholder="Click or type..." value="@Model.FilterDept" autocomplete="off" />
                <i class="fas fa-chevron-down combo-arrow" style="right:8px;top:50%;transform:translateY(-50%);position:absolute;pointer-events:none;color:var(--gray-400);font-size:.75rem;"></i>
                <div id="filterDeptDropdown" class="dept-dropdown" style="display:none;"></div>
            </div>
        </div>
        <div class="filter-group" style="position:relative;">
            <label><i class="fas fa-file-alt"></i> Document Type</label>
            <div class="combo-wrap">
                <input type="text" id="filterDocType" class="form-control sm"
                       placeholder="Click or type..." value="@Model.FilterDocType" autocomplete="off" />
                <i class="fas fa-chevron-down combo-arrow" style="right:8px;top:50%;transform:translateY(-50%);position:absolute;pointer-events:none;color:var(--gray-400);font-size:.75rem;"></i>
                <div id="filterDocTypeDrop" class="dept-dropdown" style="display:none;"></div>
            </div>
        </div>
        <button type="button" class="btn-clear" id="btnClearFilter"><i class="fas fa-times"></i> Clear</button>
    </div>

    <div class="table-responsive" id="logbookTableWrap">
        <table class="logbook-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Department / Office</th>
                    <th>Date & Time Received</th>
                    <th>Received By</th>
                    <th>Doc. Type / Code</th>
                    <th>Particulars</th>
                    <th>Remarks</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="logbookTbody">
                @if (!Model.Entries.Any())
                {
                    <tr><td colspan="8" class="empty-state"><i class="fas fa-inbox fa-2x"></i><br />No logbook entries found.</td></tr>
                }
                @{ int rowNum = (Model.CurrentPage - 1) * Model.PageSize + 1; }
                @foreach (var entry in Model.Entries)
                {
                    var docCount = entry.Documents.Count;
                    for (int di = 0; di < docCount; di++)
                    {
                        var doc = entry.Documents[di];
                        <tr class="@(di % 2 == 0 ? "row-even" : "row-odd")">
                            @if (di == 0)
                            {
                                <td rowspan="@docCount" class="row-num">@rowNum</td>
                                <td rowspan="@docCount">
                                    <span class="dept-badge">@entry.Department</span>
                                    <br /><small class="created-by"><i class="fas fa-pen fa-xs"></i> @entry.CreatedBy</small>
                                </td>
                                <td rowspan="@docCount" class="datetime-cell">
                                    <span class="date-part">@entry.DateTimeReceived.ToString("MMM dd, yyyy")</span>
                                    <br /><span class="time-part">@entry.DateTimeReceived.ToString("hh:mm tt")</span>
                                </td>
                                <td rowspan="@docCount" class="received-by-cell">
                                    <i class="fas fa-user-check"></i> @entry.ReceivedBy
                                </td>
                            }
                            <td>
                                <span class="doc-type-badge">@doc.DocumentType</span>
                                @if (!string.IsNullOrEmpty(doc.DocCode))
                                {
                                    <br /><span class="doc-code-badge">@doc.DocCode</span>
                                }
                            </td>
                            <td class="particulars-cell">@doc.Particulars</td>
                            <td class="remarks-cell">@(string.IsNullOrEmpty(doc.Remarks) ? "—" : doc.Remarks)</td>
                            @if (di == 0)
                            {
                                <td rowspan="@docCount" class="actions-cell">
                                    <a asp-action="Edit" asp-route-id="@entry.Id" class="btn-edit" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button" class="btn-delete"
                                            onclick="confirmDelete(@entry.Id, '@entry.Department.Replace("'", "\\'")')"
                                            title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                    <form id="deleteForm_@entry.Id" asp-action="Delete" asp-route-id="@entry.Id"
                                          method="post" style="display:none">
                                        @Html.AntiForgeryToken()
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                    rowNum++;
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-bar" id="paginationBar">
        @if (Model.TotalPages > 1)
        {
            @if (Model.CurrentPage > 1)
            {
                <a href="#logbookSection" class="page-btn" data-page="@(Model.CurrentPage - 1)"><i class="fas fa-chevron-left"></i></a>
            }
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <a href="#logbookSection" class="page-btn @(p == Model.CurrentPage ? "active" : "")" data-page="@p">@p</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="#logbookSection" class="page-btn" data-page="@(Model.CurrentPage + 1)"><i class="fas fa-chevron-right"></i></a>
            }
        }
    </div>
</section>

<!-- DELETE MODAL -->
<div id="deleteModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-icon modal-icon-danger"><i class="fas fa-trash-alt"></i></div>
        <h3 class="modal-title">Delete Entry?</h3>
        <p class="modal-message">You are about to delete the entry for <strong id="deleteModalDept"></strong>. This action cannot be undone.</p>
        <div class="modal-actions">
            <button type="button" class="btn-modal-cancel" onclick="closeDeleteModal()"><i class="fas fa-times"></i> Cancel</button>
            <button type="button" class="btn-modal-confirm" id="deleteModalConfirm"><i class="fas fa-trash-alt"></i> Yes, Delete</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ── DEPARTMENT DATA ───────────────────────────────────────────────────────────
const departments = [
    @foreach (var d in depts) {
        <text>{ fullName: "@d.FullName", acronym: "@d.Acronym" },</text>
    }
];

// ── DOCUMENT TYPE DATA ────────────────────────────────────────────────────────
const docTypes = [
    @foreach (var t in docTypes) {
        <text>"@t",</text>
    }
];

// ── GENERIC DROPDOWN HELPER ───────────────────────────────────────────────────
function renderList(items, dropEl, inputEl, onSelect) {
    if (!items.length) { dropEl.style.display = 'none'; return; }
    dropEl.innerHTML = items.map(item =>
        `<div class="dept-option" data-value="${item}"><span>${item}</span></div>`
    ).join('');
    dropEl.querySelectorAll('.dept-option').forEach(opt => {
        opt.addEventListener('mousedown', e => {
            e.preventDefault();
            inputEl.value = opt.dataset.value;
            dropEl.style.display = 'none';
            if (onSelect) onSelect(opt.dataset.value);
        });
    });
    dropEl.style.display = 'block';
}

function renderDepts(matches, dropEl, inputEl, onSelect) {
    if (!matches.length) { dropEl.style.display = 'none'; return; }
    dropEl.innerHTML = matches.map(d =>
        `<div class="dept-option" data-value="${d.fullName} (${d.acronym})">
            <span class="dept-acronym-badge">${d.acronym}</span>
            <span>${d.fullName}</span>
         </div>`
    ).join('');
    dropEl.querySelectorAll('.dept-option').forEach(opt => {
        opt.addEventListener('mousedown', e => {
            e.preventDefault();
            inputEl.value = opt.dataset.value;
            dropEl.style.display = 'none';
            if (onSelect) onSelect(opt.dataset.value);
        });
    });
    dropEl.style.display = 'block';
}

// ── DEPT COMBO (New Entry) ────────────────────────────────────────────────────
const deptInput    = document.getElementById('deptInput');
const deptDropdown = document.getElementById('deptDropdown');
deptInput.addEventListener('click', () => renderDepts(deptInput.value.trim() ? departments.filter(d => d.fullName.toLowerCase().includes(deptInput.value.toLowerCase()) || d.acronym.toLowerCase().includes(deptInput.value.toLowerCase())) : departments, deptDropdown, deptInput));
deptInput.addEventListener('input', () => renderDepts(deptInput.value.trim() ? departments.filter(d => d.fullName.toLowerCase().includes(deptInput.value.toLowerCase()) || d.acronym.toLowerCase().includes(deptInput.value.toLowerCase())) : departments, deptDropdown, deptInput));
deptInput.addEventListener('blur', () => setTimeout(() => deptDropdown.style.display = 'none', 150));

// ── FILTER — DEPT ─────────────────────────────────────────────────────────────
const filterDeptEl   = document.getElementById('filterDept');
const filterDeptDrop = document.getElementById('filterDeptDropdown');

filterDeptEl.addEventListener('click', function () {
    const q = this.value.trim().toLowerCase();
    const list = q ? departments.filter(d =>
        d.fullName.toLowerCase().includes(q) || d.acronym.toLowerCase().includes(q)
    ) : departments;
    renderDepts(list, filterDeptDrop, filterDeptEl, function(val) {
        _currentPage = 1;
        loadTableAjax();
    });
});

filterDeptEl.addEventListener('input', function () {
    const q = this.value.trim().toLowerCase();
    const list = q ? departments.filter(d =>
        d.fullName.toLowerCase().includes(q) || d.acronym.toLowerCase().includes(q)
    ) : departments;
    renderDepts(list, filterDeptDrop, filterDeptEl, function(val) {
        _currentPage = 1;
        loadTableAjax();
    });
    clearTimeout(filterDeptEl._t);
    filterDeptEl._t = setTimeout(() => loadTableAjax(), 400);
});

filterDeptEl.addEventListener('blur', () => setTimeout(() => filterDeptDrop.style.display = 'none', 150));

// ── FILTER — DOC TYPE ─────────────────────────────────────────────────────────
const filterDocTypeEl   = document.getElementById('filterDocType');
const filterDocTypeDrop = document.getElementById('filterDocTypeDrop');

filterDocTypeEl.addEventListener('click', function () {
    const q = this.value.trim().toLowerCase();
    const list = q ? docTypes.filter(t => t.toLowerCase().includes(q)) : docTypes;
    renderList(list, filterDocTypeDrop, filterDocTypeEl, function(val) {
        _currentPage = 1;
        loadTableAjax();
    });
});

filterDocTypeEl.addEventListener('input', function () {
    const q = this.value.trim().toLowerCase();
    const list = q ? docTypes.filter(t => t.toLowerCase().includes(q)) : docTypes;
    renderList(list, filterDocTypeDrop, filterDocTypeEl, function(val) {
        _currentPage = 1;
        loadTableAjax();
    });
    clearTimeout(filterDocTypeEl._t);
    filterDocTypeEl._t = setTimeout(() => loadTableAjax(), 400);
});

filterDocTypeEl.addEventListener('blur', () => setTimeout(() => filterDocTypeDrop.style.display = 'none', 150));

// ── AUTO FILTER on date change ────────────────────────────────────────────────
document.getElementById('filterFrom').addEventListener('change', () => { _currentPage = 1; loadTableAjax(); });
document.getElementById('filterTo').addEventListener('change',   () => { _currentPage = 1; loadTableAjax(); });

// ── CLEAR FILTER ──────────────────────────────────────────────────────────────
document.getElementById('btnClearFilter').addEventListener('click', () => {
    document.getElementById('filterFrom').value    = '';
    document.getElementById('filterTo').value      = '';
    document.getElementById('filterDept').value    = '';
    document.getElementById('filterDocType').value = '';
    _currentPage = 1; loadTableAjax();
});

// ── AJAX TABLE LOAD ───────────────────────────────────────────────────────────
let _currentPage = @Model.CurrentPage;

async function loadTableAjax(page) {
    if (page) _currentPage = page;
    const params = new URLSearchParams({
        filterFrom:    document.getElementById('filterFrom').value,
        filterTo:      document.getElementById('filterTo').value,
        filterDept:    document.getElementById('filterDept').value,
        filterDocType: document.getElementById('filterDocType').value,
        page:          _currentPage,
    });
    const tbody = document.getElementById('logbookTbody');
    const pbar  = document.getElementById('paginationBar');
    tbody.innerHTML = `<tr><td colspan="8" class="empty-state"><i class="fas fa-spinner fa-spin"></i> Loading...</td></tr>`;
    try {
        const res  = await fetch('@Url.Action("IndexPartial", "Home")?' + params.toString());
        const json = await res.json();
        tbody.innerHTML  = json.tableHtml;
        pbar.innerHTML   = json.paginationHtml;
        document.querySelector('.record-count').textContent = json.totalCount + ' total record(s)';
    } catch(e) {
        tbody.innerHTML = `<tr><td colspan="8" class="empty-state"><i class="fas fa-exclamation-triangle"></i> Error loading data.</td></tr>`;
    }
}

document.getElementById('paginationBar').addEventListener('click', e => {
    const btn = e.target.closest('.page-btn[data-page]');
    if (!btn) return; e.preventDefault(); loadTableAjax(parseInt(btn.dataset.page));
});

document.getElementById('logbookTbody').addEventListener('click', e => {
    const btn = e.target.closest('[data-delete-id]');
    if (!btn) return; confirmDelete(parseInt(btn.dataset.deleteId), btn.dataset.deleteDept);
});

// ── DOC ROW MANAGEMENT ─────── //
let rowIndex = 1;

function addDocRow() {
    const container = document.getElementById('docRows');
    const div = document.createElement('div');
    div.className = 'doc-row';
    div.innerHTML = `
        <div class="combo-wrap">
            <select name="Documents[${rowIndex}].DocumentType" class="form-control" required>
                <option value="">-- Select Type --</option>
                ${docTypes.map(t => `<option value="${t}">${t}</option>`).join('')}
            </select>
            <i class="fas fa-chevron-down combo-arrow"></i>
        </div>
        <input type="text" name="Documents[${rowIndex}].DocCode" class="form-control" placeholder="e.g. DV-001 (optional)" />
        <input type="text" name="Documents[${rowIndex}].Particulars" class="form-control" placeholder="Document particulars..." />
        <input type="text" name="Documents[${rowIndex}].Remarks" class="form-control" placeholder="Note/Annotation" />
        <button type="button" class="btn-remove-row" onclick="removeRow(this)"><i class="fas fa-times"></i></button>`;
    container.appendChild(div);
    rowIndex++;
    updateRemoveButtons();
}

function removeRow(btn) { btn.closest('.doc-row').remove(); reindexRows(); updateRemoveButtons(); }

function reindexRows() {
    document.querySelectorAll('#docRows .doc-row').forEach((row, i) => {
        row.querySelectorAll('input').forEach(inp => { inp.name = inp.name.replace(/\[\d+\]/, `[${i}]`); });
    });
    rowIndex = document.querySelectorAll('#docRows .doc-row').length;
}

function updateRemoveButtons() {
    const rows = document.querySelectorAll('#docRows .doc-row');
    rows.forEach(r => { r.querySelector('.btn-remove-row').disabled = rows.length === 1; });
}

// ── DELETE MODAL ──────────────────────────────────────────────────────────────
let _pendingDeleteId = null;
function confirmDelete(id, dept) { _pendingDeleteId = id; document.getElementById('deleteModalDept').textContent = dept; document.getElementById('deleteModal').style.display = 'flex'; }
function closeDeleteModal() { _pendingDeleteId = null; document.getElementById('deleteModal').style.display = 'none'; }
document.getElementById('deleteModalConfirm').addEventListener('click', () => {
    if (_pendingDeleteId !== null) { document.getElementById('deleteForm_' + _pendingDeleteId)?.submit(); }
});
document.getElementById('deleteModal').addEventListener('click', e => { if (e.target === document.getElementById('deleteModal')) closeDeleteModal(); });
// ── EXPORT CSV ────────────────────────────────────────────────────────────────
function exportCsv() {
    const params = new URLSearchParams({
        filterFrom:    document.getElementById('filterFrom').value,
        filterTo:      document.getElementById('filterTo').value,
        filterDept:    document.getElementById('filterDept').value,
        filterDocType: document.getElementById('filterDocType').value,
    });
    window.location.href = '@Url.Action("ExportCsv", "Home")?' + params.toString();
}

// ── PRINT PREVIEW ─────────────────────────────────────────────────────────────
function printPreview() {
    const params = new URLSearchParams({
        filterFrom:    document.getElementById('filterFrom').value,
        filterTo:      document.getElementById('filterTo').value,
        filterDept:    document.getElementById('filterDept').value,
        filterDocType: document.getElementById('filterDocType').value,
    });
    window.open('@Url.Action("PrintPreview", "Home")?' + params.toString(), '_blank');
}
</script>
}