@{
    ViewData["Title"] = "Audit Trail";
    var logs = ViewBag.Logs as List<DepEdLogbook.Models.AuditLog> ?? new();
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<section class="logbook-section" style="max-width:1000px;margin:2rem auto;">
    <div class="section-header">
        <h2><i class="fas fa-clipboard-list"></i> Audit Trail</h2>
        <a asp-action="Index" class="btn-back"><i class="fas fa-arrow-left"></i> Back to Logbook</a>
    </div>

    <div class="table-responsive">
        <table class="logbook-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Action</th>
                    <th>Details</th>
                    <th>Performed By</th>
                    <th>Timestamp</th>
                </tr>
            </thead>
            <tbody>
                @if (!logs.Any())
                {
                    <tr><td colspan="5" class="empty-state"><i class="fas fa-inbox fa-2x"></i><br/>No audit logs found.</td></tr>
                }
                @{ int n = (currentPage - 1) * 20 + 1; }
                @foreach (var log in logs)
                {
                    <tr>
                        <td>@n</td>
                        <td>
                            <span class="action-badge action-@log.Action.ToLower()">@log.Action</span>
                        </td>
                        <td>@log.Details</td>
                        <td><i class="fas fa-user"></i> @log.PerformedBy</td>
                        <td class="datetime-cell">
                            <span class="date-part">@log.Timestamp.ToString("MMM dd, yyyy")</span>
                            <br /><span class="time-part">@log.Timestamp.ToString("hh:mm:ss tt")</span>
                        </td>
                    </tr>
                    n++;
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination-bar">
            @if (currentPage > 1)
            {
                <a asp-action="AuditTrail" asp-route-page="@(currentPage - 1)" class="page-btn"><i class="fas fa-chevron-left"></i></a>
            }
            @for (int p = 1; p <= totalPages; p++)
            {
                <a asp-action="AuditTrail" asp-route-page="@p" class="page-btn @(p == currentPage ? "active" : "")">@p</a>
            }
            @if (currentPage < totalPages)
            {
                <a asp-action="AuditTrail" asp-route-page="@(currentPage + 1)" class="page-btn"><i class="fas fa-chevron-right"></i></a>
            }
        </div>
    }
</section>
