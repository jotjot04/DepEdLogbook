@model DepEdLogbook.Models.AppUser
@{
    ViewData["Title"] = "Edit Account";
}

<section class="form-section" style="max-width:500px;margin:2rem auto;">
    <div class="section-header">
        <h2><i class="fas fa-user-edit"></i> Edit Account — @Model.UnitFullName</h2>
        <a asp-action="Accounts" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <form asp-action="EditAccount" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group" style="margin-bottom:1rem;">
            <label class="form-label"><i class="fas fa-building"></i> Unit</label>
            <input type="text" class="form-control" value="@Model.UnitFullName" disabled />
        </div>

        <div class="form-group" style="margin-bottom:1rem;">
            <label class="form-label"><i class="fas fa-user"></i> Username</label>
            <input type="text" name="Username" class="form-control" value="@Model.Username" required />
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
            <label class="form-label"><i class="fas fa-lock"></i> Password</label>
            <input type="text" name="Password" class="form-control" value="@Model.Password" required />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i> Save Changes
            </button>
        </div>
    </form>
</section>
